# Normalize text files to LF in the repo; let Git pick native endings on checkout.
* text=auto

# Files that are executed or parsed on the Linux VPS must stay LF even when
# checked out on Windows — a CRLF shebang or unit line breaks the deploy
# (exec'd over SSH). See deploy/README.md.
*.sh        text eol=lf
*.service   text eol=lf
deploy/nginx.conf text eol=lf
